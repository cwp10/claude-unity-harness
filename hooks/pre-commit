#!/bin/sh
# ============================================================
# Claude Code pre-commit hook (Unity 전용)
# Windows (Git Bash) / macOS 크로스 플랫폼 지원
#
# 흐름:
#   1. .meta 누락 파일 감지 → 자동 git add
#      여전히 누락 있으면 커밋 차단 (에디터에서 저장 필요)
#   2. Unity 컴파일 검증 (MCP 우선 → batchmode fallback)
#      실패 시 커밋 차단
#
# 리뷰·문서화는 /git-summary, /review 스킬로 커밋 전에 실행하세요.
#
# 설치: /setup 실행 시 자동 설치
#   또는 PowerShell에서 (프로젝트 루트에서 실행):
#   powershell -ExecutionPolicy Bypass -File ".\.claude\hooks\install-hooks.ps1"
# ============================================================

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

# ── MCP 연결 확인 함수 ────────────────────────────────────
check_mcp_connected() {
    if command -v curl > /dev/null 2>&1; then
        curl -s --max-time 2 http://127.0.0.1:8080 > /dev/null 2>&1
        return $?
    elif command -v powershell > /dev/null 2>&1; then
        powershell -NoProfile -Command \
            "try{(New-Object System.Net.Sockets.TcpClient('127.0.0.1',8080)).Close();exit 0}catch{exit 1}" \
            > /dev/null 2>&1
        return $?
    fi
    return 1
}

# ── claude CLI 확인 (컴파일 MCP 체크용) ───────────────────
CLAUDE_CMD=""
if command -v claude > /dev/null 2>&1; then
    CLAUDE_CMD="claude"
elif [ -f "$APPDATA/npm/claude.cmd" ]; then
    CLAUDE_CMD="$APPDATA/npm/claude.cmd"
fi

# ── 초기 커밋 여부 확인 (빈 저장소 대응) ─────────────────────
IS_INITIAL_COMMIT=false
git rev-parse --verify HEAD > /dev/null 2>&1 || IS_INITIAL_COMMIT=true

# ── 변경된 .cs 파일 확인 ────────────────────────────────────
if [ "$IS_INITIAL_COMMIT" = true ]; then
    CHANGED_CS=$(git ls-files --cached 2>/dev/null | grep '\.cs$' || true)
else
    CHANGED_CS=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep '\.cs$' || true)
fi

if [ -z "$CHANGED_CS" ]; then
    printf "${GREEN}.cs 파일 변경 없음 — 검사 생략.${NC}\n\n"
    exit 0
fi

# ============================================================
# STEP 1/2: .meta 파일 처리
# ============================================================
printf "\n"
printf "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
printf "${CYAN}  [1/2] .meta 파일 확인${NC}\n"
printf "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n\n"

if [ "$IS_INITIAL_COMMIT" = true ]; then
    STAGED_ASSETS=$(git ls-files --cached 2>/dev/null \
        | grep -E '\.(cs|prefab|asset|unity|mat|anim|controller|png|jpg|fbx)$' || true)
else
    STAGED_ASSETS=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
        | grep -E '\.(cs|prefab|asset|unity|mat|anim|controller|png|jpg|fbx)$' || true)
fi

MISSING_META=""
AUTO_ADDED=""

if [ -n "$STAGED_ASSETS" ]; then
    while IFS= read -r asset; do
        META="${asset}.meta"
        if [ -f "$META" ]; then
            ALREADY_STAGED=""
            if [ "$IS_INITIAL_COMMIT" = true ]; then
                git ls-files --cached 2>/dev/null | grep -qF "$META" && ALREADY_STAGED=true
            else
                git diff --cached --name-only 2>/dev/null | grep -qF "$META" && ALREADY_STAGED=true
            fi
            if [ -z "$ALREADY_STAGED" ]; then
                git add "$META"
                AUTO_ADDED="${AUTO_ADDED}  + ${META}\n"
            fi
        else
            MISSING_META="${MISSING_META}  ! ${META}\n"
        fi
    done << ASSET_EOF
$STAGED_ASSETS
ASSET_EOF
fi

if [ -n "$AUTO_ADDED" ]; then
    printf "${GREEN}.meta 파일 자동 추가:${NC}\n"
    printf "$AUTO_ADDED"
    printf "\n"
fi

if [ -n "$MISSING_META" ]; then
    printf "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
    printf "${RED}  커밋 차단: .meta 파일 누락${NC}\n"
    printf "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n\n"
    printf "누락된 .meta 파일:\n"
    printf "$MISSING_META"
    printf "\n해결 방법:\n"
    printf "  1. Unity 에디터에서 프로젝트를 저장하세요 (Ctrl+S)\n"
    printf "  2. Unity가 .meta 파일을 생성하면 다시 커밋하세요\n"
    printf "     git add . && git commit\n\n"
    printf "  긴급 시 강제 커밋:\n"
    printf "    git commit --no-verify\n\n"
    exit 1
fi

printf "${GREEN}  .meta 파일 확인 완료.${NC}\n\n"

# ============================================================
# STEP 2/2: Unity 컴파일 검증 (MCP 우선 → batchmode fallback)
# ============================================================
printf "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
printf "${CYAN}  [2/2] Unity 컴파일 검증${NC}\n"
printf "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n\n"

COMPILE_CHECKED=false
VERSION_FILE="ProjectSettings/ProjectVersion.txt"

# ── 2A: MCP 컴파일 확인 (Unity Editor 실행 중일 때) ──────────
if [ -n "$CLAUDE_CMD" ] && check_mcp_connected; then
    printf "  ${CYAN}Unity MCP 연결됨 → read_console로 컴파일 확인 중...${NC}\n\n"

    CONSOLE_RESULT=$($CLAUDE_CMD -p --bare \
"UnityMCP의 read_console 툴을 호출해서 현재 컴파일 에러를 확인해줘.
컴파일 에러(Error 레벨)가 있으면 각각 'COMPILE_ERROR: [에러 내용]' 형식으로 출력.
에러가 없으면 첫 줄에 정확히 'COMPILE_OK' 만 출력." \
        2>/dev/null) || CONSOLE_RESULT=""

    if echo "$CONSOLE_RESULT" | grep -q "^COMPILE_OK"; then
        printf "  ${GREEN}컴파일 성공 (MCP).${NC}\n\n"
        COMPILE_CHECKED=true
    elif echo "$CONSOLE_RESULT" | grep -q "^COMPILE_ERROR:"; then
        printf "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
        printf "${RED}  커밋 차단: 컴파일 에러 발생 (MCP)${NC}\n"
        printf "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n\n"
        echo "$CONSOLE_RESULT" | grep "^COMPILE_ERROR:" | while IFS= read -r err; do
            printf "  %s\n" "$err"
        done
        printf "\n  Unity 에디터에서 에러를 수정한 후 다시 커밋하세요.\n"
        printf "\n  긴급 시 강제 커밋:\n"
        printf "    git commit --no-verify\n\n"
        exit 1
    else
        printf "  ${YELLOW}MCP 응답 불명확 → batchmode로 재확인합니다.${NC}\n\n"
    fi
fi

# ── 2B: batchmode fallback (MCP 미연결 또는 응답 불명확) ─────
if [ "$COMPILE_CHECKED" = false ]; then
    UNITY_VERSION=""
    UNITY_EXE=""

    if [ -f "$VERSION_FILE" ]; then
        UNITY_VERSION=$(grep "m_EditorVersion:" "$VERSION_FILE" | awk '{print $2}' | tr -d '\r')
        printf "  Unity 버전: %s\n" "$UNITY_VERSION"

        if [ -f ".claude/CLAUDE.md" ]; then
            CUSTOM_PATH=$(grep "UNITY_PATH:" ".claude/CLAUDE.md" | sed 's/.*UNITY_PATH: *//' | tr -d '\r')
            if [ -n "$CUSTOM_PATH" ]; then
                UNITY_EXE=$(echo "$CUSTOM_PATH" | sed 's|\\|/|g' | sed 's|^\([A-Za-z]\):|/\1|' | tr '[:upper:]' '[:lower:]')
                printf "  Unity.exe (CLAUDE.md): %s\n" "$UNITY_EXE"
            fi
        fi

        if [ -z "$UNITY_EXE" ] || [ ! -f "$UNITY_EXE" ]; then
            UNITY_EXE=""
            UNITY_EXE_C="/c/Program Files/Unity/Hub/Editor/${UNITY_VERSION}/Editor/Unity.exe"
            UNITY_EXE_D="/d/Program Files/Unity/Hub/Editor/${UNITY_VERSION}/Editor/Unity.exe"
            UNITY_EXE_MAC="/Applications/Unity/Hub/Editor/${UNITY_VERSION}/Unity.app/Contents/MacOS/Unity"
            if [ -f "$UNITY_EXE_C" ]; then
                UNITY_EXE="$UNITY_EXE_C"
            elif [ -f "$UNITY_EXE_D" ]; then
                UNITY_EXE="$UNITY_EXE_D"
            elif [ -f "$UNITY_EXE_MAC" ]; then
                UNITY_EXE="$UNITY_EXE_MAC"
            fi
        fi

        if [ -z "$UNITY_EXE" ] || [ ! -f "$UNITY_EXE" ]; then
            UNITY_EXE=""
            for HUB_DIR in \
                "/c/Program Files/Unity/Hub/Editor" \
                "/d/Program Files/Unity/Hub/Editor" \
                "/Applications/Unity/Hub/Editor"
            do
                [ -d "$HUB_DIR" ] || continue
                for VER_DIR in "$HUB_DIR"/*/; do
                    [ -d "$VER_DIR" ] || continue
                    if [ -f "${VER_DIR}Editor/Unity.exe" ]; then
                        UNITY_EXE="${VER_DIR}Editor/Unity.exe"
                        printf "  ${YELLOW}버전 불일치 폴백: %s${NC}\n" "$UNITY_EXE"
                        break 2
                    elif [ -f "${VER_DIR}Unity.app/Contents/MacOS/Unity" ]; then
                        UNITY_EXE="${VER_DIR}Unity.app/Contents/MacOS/Unity"
                        printf "  ${YELLOW}버전 불일치 폴백: %s${NC}\n" "$UNITY_EXE"
                        break 2
                    fi
                done
            done
        fi
    fi

    COMPILE_TIMEOUT=120
    if [ -f ".claude/CLAUDE.md" ]; then
        CUSTOM_TIMEOUT=$(grep "UNITY_COMPILE_TIMEOUT:" ".claude/CLAUDE.md" \
            | sed 's/.*UNITY_COMPILE_TIMEOUT: *//' | tr -d '\r' | grep '^[0-9][0-9]*$' | head -1)
        [ -n "$CUSTOM_TIMEOUT" ] && COMPILE_TIMEOUT="$CUSTOM_TIMEOUT"
    fi

    if [ -z "$UNITY_VERSION" ]; then
        printf "  ${YELLOW}ProjectSettings/ProjectVersion.txt 없음 — 컴파일 검증 생략.${NC}\n\n"
    elif [ -z "$UNITY_EXE" ] || [ ! -f "$UNITY_EXE" ]; then
        printf "  ${YELLOW}Unity.exe 경로를 찾을 수 없습니다 — 컴파일 검증 생략.${NC}\n"
        printf "  커스텀 경로 설정: .claude/CLAUDE.md 에 아래 줄 추가\n"
        printf "    UNITY_PATH: C:/Program Files/Unity/Hub/Editor/%s/Editor/Unity.exe\n" "$UNITY_VERSION"
        printf "  타임아웃 설정 (기본 120초): UNITY_COMPILE_TIMEOUT: 180\n\n"
    else
        printf "  Unity.exe: %s\n" "$UNITY_EXE"
        printf "  컴파일 검증 중... batchmode (최대 %d초)\n\n" "$COMPILE_TIMEOUT"

        COMPILE_LOG=".claude/compile_$(date -u +%Y%m%d_%H%M%S).log"
        mkdir -p ".claude"

        COMPILE_EXIT=0
        timeout "$COMPILE_TIMEOUT" "$UNITY_EXE" \
            -batchmode \
            -quit \
            -projectPath "$(pwd)" \
            -logFile "$COMPILE_LOG" \
            -executeMethod "" \
            > /dev/null 2>&1 || COMPILE_EXIT=$?

        COMPILE_ERRORS=""
        if [ -f "$COMPILE_LOG" ]; then
            COMPILE_ERRORS=$(grep -iE "^.*error (CS|Unity)[0-9]+.*$" "$COMPILE_LOG" || true)
        fi

        if [ -n "$COMPILE_ERRORS" ] || [ "$COMPILE_EXIT" -eq 124 ]; then
            printf "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
            if [ "$COMPILE_EXIT" -eq 124 ]; then
                printf "${RED}  커밋 차단: 컴파일 타임아웃 (%d초 초과)${NC}\n" "$COMPILE_TIMEOUT"
            else
                printf "${RED}  커밋 차단: 컴파일 에러 발생 (batchmode)${NC}\n"
            fi
            printf "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n\n"
            if [ -n "$COMPILE_ERRORS" ]; then
                printf "에러 목록:\n"
                echo "$COMPILE_ERRORS" | while IFS= read -r err; do
                    printf "  %s\n" "$err"
                done
                printf "\n"
            fi
            printf "  전체 로그: %s\n\n" "$COMPILE_LOG"
            printf "  긴급 시 강제 커밋:\n"
            printf "    git commit --no-verify\n\n"
            exit 1
        fi

        printf "  ${GREEN}컴파일 성공 (batchmode).${NC}\n"
        rm -f "$COMPILE_LOG"
        printf "\n"
    fi
fi

# ============================================================
# 완료
# ============================================================
printf "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
printf "${GREEN}  커밋을 진행합니다.${NC}\n"
printf "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n\n"
exit 0
